  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Hancho",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/symlinks/hancho/hancho.py",
      "cwd": "${workspaceFolder}",
      "args": ["-v"],
      "console": "integratedTerminal",
      //"justMyCode": false,
      //"preLaunchTask": "Wipe build",
    },

    {
      "name": "Debug dummy app build",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/symlinks/hancho/hancho.py",
      "cwd": "${workspaceFolder}/examples",
      "args": ["-v"],
      "console": "integratedTerminal",
      //"justMyCode": false,
      //"preLaunchTask": "Wipe build",
    },

    {
      "name": "Debug dummy app",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/examples/build/dummy",
      "cwd": "${workspaceFolder}/examples",
      //"justMyCode": false,
      //"preLaunchTask": "Wipe build",
    },
  ]
}
